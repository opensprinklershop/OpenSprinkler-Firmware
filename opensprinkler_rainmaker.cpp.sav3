/* OpenSprinkler – Trivial RainMaker (single switch → Zone 1, 10 s)
 * + On-Network provisioning (local_ctrl + mDNS + challenge-response)
 *
 * Minimum to verify that:
 *   1. RMaker.initNode() + RMaker.start() succeed
 *   2. The ESP RainMaker phone app can DISCOVER the device
 *   3. A switch toggle actually turns Zone 1 on/off
 */

#include "defines.h"

#if defined(ESP32) && defined(ENABLE_RAINMAKER)

#include "opensprinkler_rainmaker.h"
#include "OpenSprinkler.h"
#include "program.h"

#include "RMaker.h"

