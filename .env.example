# fw.sh – local configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# All values here are optional — fw.sh falls back to built-in defaults
# when a variable is unset or empty.

# ── ESP32 / ESP8266 Device ───────────────────────────────────────────────────
# IP address of the OpenSprinkler device for OTA / API / switch commands.
OS_IP=192.168.0.151

# Device admin password (plain text — will be MD5-hashed by fw.sh).
# Alternatively set OS_HASH to supply the MD5 directly.
OS_PASSWORD=
OS_HASH=

# ── Serial / USB Upload ──────────────────────────────────────────────────────
UPLOAD_PORT=/dev/ttyUSB2
UPLOAD_SPEED=460800

# ── OsPi (Raspberry Pi) Remote Build ────────────────────────────────────────
# IP / hostname of the Raspberry Pi running OpenSprinkler.
OSPI_PI_HOST=192.168.0.167

# SSH login user on the Pi.
OSPI_PI_USER=pi

# SSH password for the Pi user.
# Leave empty if you use SSH key authentication (ssh-copy-id pi@<host>).
OSPI_PI_PASS=

# Firmware directory on the Pi.
OSPI_PI_DIR=/home/pi/OpenSprinkler-Firmware

# ── Release / Upgrade Server ─────────────────────────────────────────────────
# Local path where firmware binaries are published for OTA upgrades.
OS_UPGRADE_DIR=/srv/www/htdocs/upgrade

# GitHub personal access token (required only for ./fw.sh release).
GITHUB_TOKEN=
